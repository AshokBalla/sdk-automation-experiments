{
    "all": true,
    "include": [
        "features/**/*.js",
        "*.js"
    ],
    "exclude": [
        "node_modules/**",
        "coverage/**",
        "**/*.test.js",
        "**/*.spec.js"
    ],
    "reporter": [
        "html",
        "text",
        "lcov"
    ],
    "check-coverage": false,
    "branches": 80,
    "lines": 80,
    "functions": 80,
    "statements": 80
}