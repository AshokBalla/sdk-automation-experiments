{
    "type": "module",
    "name": "credit-card-sdk",
    "version": "1.0.0",
    "description": "Credit Card SDK Test Suite",
    "main": "run-tests.js",
    "scripts": {
        "test": "cucumber-js --config creditsdkcucumber.js",
        "test:reports": "node generate-reports.js",
        "test:with-reports": "cucumber-js --config creditsdkcucumber.js --format json:reports/cucumber-report.json && node generate-reports.js",
        "test:all": "node run-tests-with-reports.js",
        "test:coverage": "c8 --reporter=html --reporter=text --reporter=lcov --reporter=json cucumber-js --config creditsdkcucumber.js",
        "test:coverage:html": "c8 --reporter=html cucumber-js --config creditsdkcucumber.js",
        "test:coverage:lcov": "c8 --reporter=lcov cucumber-js --config creditsdkcucumber.js"
    },
    "keywords": [
        "testing",
        "cucumber",
        "credit-card",
        "sdk"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "puppeteer": "^23.4.1"
    },
    "devDependencies": {
        "@babel/core": "^7.28.3",
        "@babel/register": "^7.28.3",
        "@cucumber/cucumber": "^11.0.1",
        "@cucumber/html-formatter": "^21.14.0",
        "@cucumber/pretty-formatter": "^2.1.0",
        "c8": "^10.1.3",
        "dotenv": "^16.4.7",
        "multiple-cucumber-html-reporter": "^3.5.0"
    }
}