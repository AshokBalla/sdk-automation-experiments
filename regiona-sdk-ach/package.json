{
  "name": "can-sdk",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --config cucumber.js",
    "test:canach": "cucumber-js features/canach.feature",
    "test:reports": "node generate-reports.js",
    "test:with-reports": "cucumber-js && node generate-reports.js",
    "test:all": "node run-tests-with-reports.js",
    "test:coverage": "c8 --reporter=html --reporter=text --reporter=lcov --reporter=json cucumber-js",
    "test:coverage:html": "c8 --reporter=html cucumber-js",
    "test:coverage:lcov": "c8 --reporter=lcov cucumber-js",
    "test:coverage:nyc": "nyc cucumber-js",
    "coverage:report": "nyc report --reporter=html",
    "coverage:lcov": "nyc report --reporter=lcov"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "description": "",
  "dependencies": {
    "cucumber": "^6.0.7",
    "puppeteer": "^24.17.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.1",
    "@cucumber/pretty-formatter": "^2.0.1",
    "nyc": "^15.1.0",
    "c8": "^10.1.3",
    "multiple-cucumber-html-reporter": "^3.5.0"
  },
  "nyc": {
    "all": true,
    "check-coverage": true,
    "branches": 100,
    "lines": 100,
    "functions": 100,
    "statements": 100,
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "exclude": [
      "node_modules/**",
      "coverage/**",
      "*.test.js",
      "*.spec.js"
    ]
  }
}