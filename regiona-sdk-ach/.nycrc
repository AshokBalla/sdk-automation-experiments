{
  "all": true,
  "check-coverage": true,
  "branches": 100,
  "lines": 100,
  "functions": 100,
  "statements": 100,
  "reporter": [
    "text",
    "html",
    "lcov",
    "json"
  ],
  "exclude": [
    "node_modules/**",
    "coverage/**",
    "*.test.js",
    "*.spec.js",
    "features/**",
    "step_defs/**"
  ],
  "include": [
    "*.js",
    "canach.js"
  ],
  "sourceMap": false,
  "instrument": true
}